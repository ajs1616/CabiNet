# TFTP root: served config is LOAD-BEARING and versioned — DHCP option 67
# points clients at these files (igt/g2s.xml is what the AVP path hands
# out), and BENCH_BRINGUP_WMS.md §7 says new capture-driven files must be
# committed. The old blanket 'tftp-root/' ignore made fixes to served
# config invisible to git (deploy only worked because push_to_pi.sh rsyncs
# the working tree). Only the top-level files that
# G2S/python/web/universal_discovery.py REGENERATES at runtime stay ignored.
G2S/tftp-root/g2s.txt
G2S/tftp-root/g2s.xml
G2S/tftp-root/config.ini
G2S/tftp-root/discovery.json
# universal_discovery.py can also spawn a nested tftp-root next to itself
G2S/python/web/tftp-root/

# Process ID files
.openg2s_pids
*.pid

# Archives
*.zip
*.tar.gz

# admin flag migration one-shot marker (per-deployment runtime state)
G2S/data/.admin_migration_done

# Test caches
.pytest_cache/

# Runtime state (never commit a floor's live data)
G2S/data/
SAS/data/
Companion/data/
*.db
*.db-wal
*.db-shm
.openg2s_pids
