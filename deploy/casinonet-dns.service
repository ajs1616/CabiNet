[Unit]
Description=CabiNet DNS discovery (slot network, pinned to eth0)
After=network.target casinonet-dhcp.service
Wants=network.target

[Service]
Type=simple
WorkingDirectory=/home/aj/CasinoNet/G2S
ExecStart=/usr/bin/python3 -u tools/run_dns_discovery.py --interface eth0 --server-ip 192.168.50.2
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
